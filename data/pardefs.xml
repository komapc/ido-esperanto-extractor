<pardefs>
    <pardef n="o__n">
      <e>
        <p>
          <l>o</l>
          <r><s n="n"/><s n="sg"/><s n="nom"/></r>
        </p>
      </e>
      <e>
        <p>
          <l>i</l>
          <r><s n="n"/><s n="pl"/><s n="nom"/></r>
        </p>
      </e>
      <!-- Adjectival derivation from nouns: suces+oza → sucesoza (full of success).
           Include <sg><nom> so remaining tags feed Epo autogen correctly. -->
      <e><p><l>oza</l><r><s n="n"/><s n="der_oz"/><s n="adj"/><s n="sg"/><s n="nom"/></r></p></e>
    </pardef>
    <pardef n="a__adj">
      <e>
        <p>
          <l>a</l>
          <r><s n="adj"/></r>
        </p>
      </e>
      <!-- Quality nouns: bon+eso → boneso (goodness); maps to Epo bon+eco -->
      <e><p><l>eso</l><r><s n="adj"/><s n="der_qual"/><s n="n"/><s n="sg"/><s n="nom"/></r></p></e>
      <e><p><l>esi</l><r><s n="adj"/><s n="der_qual"/><s n="n"/><s n="pl"/><s n="nom"/></r></p></e>
    </pardef>
    <pardef n="ebl__adj">
      <e>
        <p>
          <l>ebla</l>
          <r><s n="adj"/></r>
        </p>
      </e>
    </pardef>
    <pardef n="e__adv">
      <e>
        <p>
          <l>e</l>
          <r><s n="adv"/></r>
        </p>
      </e>
    </pardef>
    <pardef n="ar__vblex">
      <e>
        <p>
          <l>ar</l>
          <r><s n="vblex"/><s n="inf"/></r>
        </p>
      </e>
      <e>
        <p>
          <l>as</l>
          <r><s n="vblex"/><s n="pri"/></r>
        </p>
      </e>
      <e>
        <p>
          <l>is</l>
          <r><s n="vblex"/><s n="pii"/></r>
        </p>
      </e>
      <e>
        <p>
          <l>os</l>
          <r><s n="vblex"/><s n="fti"/></r>
        </p>
      </e>
      <e>
        <p>
          <l>us</l>
          <r><s n="vblex"/><s n="cni"/></r>
        </p>
      </e>
      <e>
        <p>
          <l>ez</l>
          <r><s n="vblex"/><s n="imp"/></r>
        </p>
      </e>
      <!-- Present-agent nouns: kre+anto → kreanto (one who creates) -->
      <e><p><l>anto</l><r><s n="vblex"/><s n="der_pres"/><s n="n"/><s n="sg"/><s n="nom"/></r></p></e>
      <e><p><l>anti</l><r><s n="vblex"/><s n="der_pres"/><s n="n"/><s n="pl"/><s n="nom"/></r></p></e>
      <!-- Action nouns: kre+ado → kreado (the act of creating) -->
      <e><p><l>ado</l><r><s n="vblex"/><s n="der_act"/><s n="n"/><s n="sg"/><s n="nom"/></r></p></e>
      <e><p><l>adi</l><r><s n="vblex"/><s n="der_act"/><s n="n"/><s n="pl"/><s n="nom"/></r></p></e>
      <!-- Past-agent nouns: kre+into → kreinto (one who created) -->
      <e><p><l>into</l><r><s n="vblex"/><s n="der_past"/><s n="n"/><s n="sg"/><s n="nom"/></r></p></e>
      <e><p><l>inti</l><r><s n="vblex"/><s n="der_past"/><s n="n"/><s n="pl"/><s n="nom"/></r></p></e>
      <!-- Past-active participle (adj): kre+inta → kreinta; needs <sg> (no <nom>) for pp3 Epo generation -->
      <e><p><l>inta</l><r><s n="vblex"/><s n="der_ppa"/><s n="adj"/><s n="sg"/></r></p></e>
      <!-- Past-passive participle (adj): kre+ita → kreita (created) -->
      <e><p><l>ita</l><r><s n="vblex"/><s n="der_ppas"/><s n="adj"/><s n="sg"/><s n="nom"/></r></p></e>
      <!-- Present-passive participle (adj): kre+ata → kreata (being created) -->
      <e><p><l>ata</l><r><s n="vblex"/><s n="der_pprs"/><s n="adj"/><s n="sg"/><s n="nom"/></r></p></e>
      <!-- Future-passive participle (adj): kre+ota → kreota (about to be created) -->
      <e><p><l>ota</l><r><s n="vblex"/><s n="der_pfut"/><s n="adj"/><s n="sg"/><s n="nom"/></r></p></e>
      <!-- Present-active participle (adj): kre+anta → kreanta (creating) -->
      <e><p><l>anta</l><r><s n="vblex"/><s n="der_ppra"/><s n="adj"/><s n="sg"/><s n="nom"/></r></p></e>
    </pardef>
    <pardef n="num">
      <e>
        <p>
          <l/>
          <r><s n="num"/></r>
        </p>
      </e>
    </pardef>
    <pardef n="num_regex">
      <e>
        <re>[0-9]+([.,][0-9]+)*</re>
        <p>
          <l/>
          <r><s n="num"/><s n="ciph"/><s n="sp"/><s n="nom"/></r>
        </p>
      </e>
    </pardef>
    <pardef n="__pr">
