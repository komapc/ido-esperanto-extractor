      </e>
    </pardef>
    <pardef n="__det">
      <e>
        <p>
          <l/>
          <r><s n="det"/></r>
        </p>
      </e>
    </pardef>
    <pardef n="__prn">
      <e>
        <p>
          <l/>
          <r><s n="prn"/></r>
        </p>
      </e>
    </pardef>
    <pardef n="__adv">
      <e>
        <p>
          <l/>
          <r><s n="adv"/></r>
        </p>
      </e>
    </pardef>
    <pardef n="__cnjcoo">
      <e>
        <p>
          <l/>
          <r><s n="cnjcoo"/></r>
        </p>
      </e>
    </pardef>
    <pardef n="__cnjsub">
      <e>
        <p>
          <l/>
          <r><s n="cnjsub"/></r>
        </p>
      </e>
    </pardef>
    <pardef n="ma__ord">
      <e>
        <p>
          <l>ma</l>
          <r><s n="num" /><s n="ord" /></r>
        </p>
      </e>
      <e>
        <p>
          <l>esma</l>
          <r><s n="num" /><s n="ord" /></r>
        </p>
      </e>
    </pardef>
    <pardef n="__invar_verb">
      <e>
        <p>
          <l />
          <r><s n="vblex" /><s n="pri" /></r>
        </p>
      </e>
    </pardef>
    <pardef n="np__np">
      <e>
        <p>
          <l/>
          <r><s n="np"/></r>
        </p>
      </e>
    </pardef>
    <pardef n="__prep_art">
      <e>
        <p>
          <l/>
          <r><s n="pr"/><s n="def"/></r>
        </p>
      </e>
    </pardef>
  </pardefs>